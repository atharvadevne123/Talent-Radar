# Talent-Radar Environment Variables
# Copy this file to .env and fill in your values.

# Database
DATABASE_URL=postgresql://talent:talent@localhost:5432/talent_radar
# For local SQLite testing:
# DATABASE_URL=sqlite:///./talent_radar.db

# Model
MODEL_PATH=models/talent_radar.pkl
MODEL_VERSION=1.0.0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
LOG_LEVEL=INFO

# Drift monitoring
DRIFT_ALPHA=0.05

# Optional: MLflow experiment tracking
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=talent-radar-salary
